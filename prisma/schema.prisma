// ═══════════════════════════════════════════════════════════════════════════════
// UNIFIED FORM RECORD (replaces 15 sharded tables)
// ═══════════════════════════════════════════════════════════════════════════════

model FormRecord {
  id             String            @id @default(cuid())
  formId         String            @map("form_id")
  form           Form              @relation("FormRecords", fields: [formId], references: [id], onDelete: Cascade)
  recordData     Json              @default("{}") @map("record_data")
  organizationId String?           @map("organization_id")
  employee_id    String?
  amount         Decimal?
  date           DateTime?
  submittedBy    String?           @map("submitted_by")
  submittedAt    DateTime          @default(now()) @map("submitted_at")
  ipAddress      String?           @map("ip_address")
  userAgent      String?           @map("user_agent")
  status         String            @default("submitted")
  userId         String?           @map("user_id")
  user           User?             @relation("FormRecordUser", fields: [userId], references: [id], onDelete: SetNull)
  indexedFields  FormRecordField[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([formId])
  @@index([organizationId])
  @@index([submittedAt])
  @@index([status])
  @@index([employee_id])
  @@index([date])
  @@index([userId])
  @@map("form_records")
}

model FormRecordField {
  id              String     @id @default(cuid())
