// ─────────────────────────────────────────────────────────────────────────────
// AI / Chatbot — cloud provider registry with multi-key rotation
// Design: OpenAI-compatible upstream only. Providers speak POST /v1/chat/completions.
// Keys are AES-256-GCM encrypted at rest; rotator lives in-process (swap for Redis later).
// ─────────────────────────────────────────────────────────────────────────────

model AIProvider {
  id              String          @id @default(cuid())
  organizationId  String          @map("organization_id")
  name            String // slug: "openai", "groq", "openrouter", "anthropic", "gemini", "together", "deepinfra", "custom"
  displayName     String          @map("display_name")
  baseUrl         String          @map("base_url")
  defaultModel    String          @map("default_model")
  availableModels Json            @default("[]") @map("available_models")
  isActive        Boolean         @default(true) @map("is_active")
  isDefault       Boolean         @default(false) @map("is_default")
  priority        Int             @default(0)
  temperature     Float?          @default(0.7)
  maxTokens       Int?            @map("max_tokens")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  apiKeys         AIProviderKey[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isActive])
  @@index([isDefault])
  @@map("ai_providers")
}

model AIProviderKey {
  id             String     @id @default(cuid())
  providerId     String     @map("provider_id")
  provider       AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  organizationId String     @map("organization_id")
  label          String
  encryptedKey   String     @map("encrypted_key")
  keyPreview     String     @map("key_preview")
  isActive       Boolean    @default(true) @map("is_active")
  lastUsedAt     DateTime?  @map("last_used_at")
  failureCount   Int        @default(0) @map("failure_count")
  cooldownUntil  DateTime?  @map("cooldown_until")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([providerId])
  @@index([organizationId])
  @@index([isActive])
  @@map("ai_provider_keys")
}

model ChatConversation {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String        @map("organization_id")
  title          String        @default("New chat")
