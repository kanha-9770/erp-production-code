  subformRowIndex Int?       @map("subform_row_index")
  value_text      String?
  value_number    Decimal?
  value_date      DateTime?
  value_bool      Boolean?
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([formId, fieldId, value_text])
  @@index([formId, fieldId, value_number])
  @@index([formId, fieldId, value_date])
  @@index([formId, fieldId, value_bool])
  @@index([recordId])
  @@index([formId, subformId, subformRowIndex])
  @@map("form_record_fields")
}

