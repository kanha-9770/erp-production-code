model LookupSource {
  id             String                @id @default(cuid())
  name           String
  type           String
  description    String?
  sourceModuleId String?               @map("source_module_id")
  sourceModule   FormModule?           @relation(fields: [sourceModuleId], references: [id], onDelete: Cascade)
  sourceFormId   String?               @map("source_form_id")
  sourceForm     Form?                 @relation(fields: [sourceFormId], references: [id], onDelete: Cascade)
  apiEndpoint    String?               @map("api_endpoint")
  staticData     Json?                 @map("static_data")
  active         Boolean               @default(true)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  fieldRelations LookupFieldRelation[]

  @@index([type])
  @@index([active])
  @@index([sourceModuleId])
  @@index([sourceFormId])
  @@map("lookup_sources")
}

model LookupFieldRelation {
  id             String       @id @default(cuid())
  lookupSourceId String       @map("lookup_source_id")
  lookupSource   LookupSource @relation(fields: [lookupSourceId], references: [id], onDelete: Cascade)
  formFieldId    String       @map("form_field_id")
  formField      FormField    @relation(fields: [formFieldId], references: [id], onDelete: Cascade)
  formId         String       @map("form_id")
  moduleId       String       @map("module_id")
  displayField   String?      @map("display_field")
  valueField     String?      @map("value_field")
  multiple       Boolean?
  searchable     Boolean?
  filters        Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([lookupSourceId])
  @@index([formFieldId])
  @@index([formId])
  @@index([moduleId])
  @@map("lookup_field_relations")
}

model LookupTemplate {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String       @map("created_by_id")
  createdBy      User         @relation("LookupTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  config         Json // Full lookup config snapshot
  selectedFields Json // Selected fields array snapshot
  dependencies   Json? // Dependency config snapshot
  sourceInfo     Json // { moduleId, moduleName, formId, formName, sourceType }
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([createdById])
  @@map("lookup_templates")
}

model UserPermission {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId  String?     @map("permission_id")
  permission    Permission? @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  moduleId      String?     @map("module_id")
  module        FormModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade, name: "UserPermissionToFormModule")
  formId        String?     @map("form_id")
  form          Form?       @relation(fields: [formId], references: [id], onDelete: Cascade)
  resourceType  String?     @map("resource_type")
  resourceId    String?     @map("resource_id")
  granted       Boolean     @default(true)
  canView       Boolean     @default(false) @map("can_view")
  canCreate     Boolean     @default(false) @map("can_create")
  canEdit       Boolean     @default(false) @map("can_edit")
  canDelete     Boolean     @default(false) @map("can_delete")
  isSystemAdmin Boolean     @default(false) @map("is_system_admin")
  reason        String?     @default("Direct assignment")
  grantedBy     String?     @map("granted_by")
  grantedAt     DateTime    @default(now()) @map("granted_at")
  expiresAt     DateTime?   @map("expires_at")
  isActive      Boolean     @default(true) @map("is_active")
  role          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([userId, permissionId, moduleId, formId], name: "unique_user_permission")
  // Note: the prior @@unique([userId, resourceType, resourceId]) was removed
  // to allow multiple permission rows per (user, resource) — required for
  // multi-permission field/section access.
  @@index([userId])
  @@index([permissionId])
  @@index([moduleId])
  @@index([resourceType])
  @@index([resourceId])
  @@index([isActive])
  @@index([expiresAt])
  @@map("user_permissions")
}

model Employee {
  id                         String          @id @default(cuid())
  userId                     String?         @unique @map("user_id")
  user                       User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeName               String          @map("employee_name")
  gender                     Gender?         @default(OTHER)
  department                 String?
  designation                String?
  dob                        DateTime?
  nativePlace                String?         @map("native_place")
  country                    String?
  permanentAddress           String?         @map("permanent_address")
  currentAddress             String?         @map("current_address")
  personalContact            String?         @map("personal_contact")
  alternateNo1               String?         @map("alternate_no_1")
  alternateNo2               String?         @map("alternate_no_2")
  emailAddress1              String?         @map("email_address_1")
  emailAddress2              String?         @map("email_address_2")
  aadharCardUpload           String?         @map("aadhar_card_upload")
  aadharCardNo               String?         @map("aadhar_card_no")
  panCardUpload              String?         @map("pan_card_upload")
  passportUpload             String?         @map("passport_upload")
  bankName                   String?         @map("bank_name")
  bankAccountNo              String?         @map("bank_account_no")
  ifscCode                   String?         @map("ifsc_code")
  status                     EmployeeStatus? @default(ACTIVE)
  shiftType                  String?         @map("shift_type")
  inTime                     String?         @map("in_time")
  outTime                    String?         @map("out_time")
  dateOfJoining              DateTime?       @map("date_of_joining")
  dateOfLeaving              DateTime?       @map("date_of_leaving")
  incrementMonth             Int?            @map("increment_month")
  yearsOfAgreement           Int?            @map("years_of_agreement")
  bonusAfterYears            Int?            @map("bonus_after_years")
  companyName                String?         @map("company_name")
  employeeEngagementTeamName String?         @map("employee_engagement_team_name")
  totalSalary                Decimal?        @map("total_salary")
  givenSalary                Decimal?        @map("given_salary")
  bonusAmount                Decimal?        @map("bonus_amount")
  nightAllowance             Decimal?        @map("night_allowance")
  overTime                   Decimal?        @map("over_time")
  oneHourExtra               Decimal?        @map("one_hour_extra")
  companySimIssue            Boolean?        @default(false) @map("company_sim_issue")
  formRecords14              FormRecord14[]
  referralsMade              EmployeeReferral[]
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([department])
  @@index([designation])
  @@index([status])
  @@index([dateOfJoining])
  @@index([dateOfLeaving])
  @@map("employees")
}

// Workforce planning record — represents the intent to hire N people for a
// specific profile. Created by HR ahead of recruitment so vacancies and cost
// can be tracked centrally. Total estimated cost is stored (not derived) so
// list queries can sort / filter on it cheaply.
model StaffingPlan {
  id                    String              @id @default(cuid())
  planCode              String?             @unique @map("plan_code")
  profileName           String              @map("profile_name")
  department            String
  designation           String
  employmentType        EmploymentType      @map("employment_type")
  vacancies             Int                 @default(1)
  estimatedCostPerPerson Decimal?           @map("estimated_cost_per_person")
  totalEstimatedCost    Decimal?            @map("total_estimated_cost")
  status                StaffingPlanStatus  @default(DRAFT)
  notes                 String?

  organizationId        String?             @map("organization_id")
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdById           String?             @map("created_by_id")
  createdBy             User?               @relation("StaffingPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)

  jobOpenings           JobOpening[]
  jobApplications       JobApplication[]
  jobOffers             JobOffer[]

  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([department])
  @@index([status])
  @@index([employmentType])
  @@index([createdAt])
  @@map("staffing_plans")
}

// Live job posting derived (usually) from a StaffingPlan. Fields like
// profileName / company / department are duplicated so the posting keeps its
// own snapshot even if the parent plan is later edited or deleted.
model JobOpening {
  id                String           @id @default(cuid())
  jobCode           String?          @unique @map("job_code")

  staffingPlanId    String?          @map("staffing_plan_id")
  staffingPlan      StaffingPlan?    @relation(fields: [staffingPlanId], references: [id], onDelete: SetNull)

  profileName       String           @map("profile_name")
  company           String
  department        String
  designation       String
  employmentType    EmploymentType   @map("employment_type")
  vacancies         Int              @default(1)

  status            JobOpeningStatus @default(OPEN)
  publishOnWebsite  Boolean          @default(false) @map("publish_on_website")
  salaryApprox      String?          @map("salary_approx")
  jobDescription    String           @map("job_description")

  organizationId    String?          @map("organization_id")
  organization      Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdById       String?          @map("created_by_id")
  createdBy         User?            @relation("JobOpeningCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  applications      JobApplication[]
  offers            JobOffer[]

  @@index([organizationId])
  @@index([staffingPlanId])
  @@index([department])
  @@index([status])
  @@index([employmentType])
  @@index([publishOnWebsite])
  @@index([createdAt])
  @@map("job_openings")
}

// Candidate application to a JobOpening. Most fields snapshot from the
// opening at create time so audits stay accurate even after the opening is
// closed/edited.
model JobApplication {
  id                String               @id @default(cuid())
  applicationCode   String?              @unique @map("application_code")

  jobOpeningId      String?              @map("job_opening_id")
  jobOpening        JobOpening?          @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)
  staffingPlanId    String?              @map("staffing_plan_id")
  staffingPlan      StaffingPlan?        @relation(fields: [staffingPlanId], references: [id], onDelete: SetNull)

  department        String?
  designation       String?
  employmentType    EmploymentType?      @map("employment_type")

  applicantName     String               @map("applicant_name")
  applicantEmail    String               @map("applicant_email")
  applicantMobile   String               @map("applicant_mobile")
  applicantSource   ApplicantSource?     @map("applicant_source")

  applicantResumeUrl  String?            @map("applicant_resume_url")
  applicantResumeName String?            @map("applicant_resume_name")

  coverLetter       String?              @map("cover_letter")
  salaryExpectation String?              @map("salary_expectation")
  jobDescription    String?              @map("job_description")

  applicantRating   Int?                 @map("applicant_rating")
  status            JobApplicationStatus @default(NEW)

  organizationId    String?              @map("organization_id")
  organization      Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdById       String?              @map("created_by_id")
  createdBy         User?                @relation("JobApplicationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  offers              JobOffer[]
  appointmentLetters  AppointmentLetter[]

  @@index([organizationId])
  @@index([jobOpeningId])
  @@index([staffingPlanId])
  @@index([status])
  @@index([applicantSource])
  @@index([applicantEmail])
  @@index([createdAt])
  @@map("job_applications")
}

// Formal offer extended to a candidate, almost always derived from an
// accepted JobApplication. Applicant identity is snapshotted so the offer
// stays meaningful even if the application is later deleted or anonymised.
model JobOffer {
  id                  String           @id @default(cuid())
  offerCode           String?          @unique @map("offer_code")

  jobApplicationId    String?          @map("job_application_id")
  jobApplication      JobApplication?  @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  jobOpeningId        String?          @map("job_opening_id")
  jobOpening          JobOpening?      @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)
  staffingPlanId      String?          @map("staffing_plan_id")
  staffingPlan        StaffingPlan?    @relation(fields: [staffingPlanId], references: [id], onDelete: SetNull)

  applicantName       String           @map("applicant_name")
  applicantEmail      String?          @map("applicant_email")

  offerDate           DateTime         @map("offer_date")
  status              JobOfferStatus   @default(DRAFT)

  jobOfferTerm        String?          @map("job_offer_term")
  valueDescription    String?          @map("value_description")
  termsAndConditions  String?          @map("terms_and_conditions")

  organizationId      String?          @map("organization_id")
  organization        Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdById         String?          @map("created_by_id")
  createdBy           User?            @relation("JobOfferCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  appointmentLetters  AppointmentLetter[]

  @@index([organizationId])
  @@index([jobApplicationId])
  @@index([jobOpeningId])
  @@index([staffingPlanId])
  @@index([status])
  @@index([offerDate])
  @@index([createdAt])
  @@map("job_offers")
}

// Formal appointment letter generated after an offer is accepted. Mirrors
// the offer's applicant snapshot so revoking/deleting upstream records
// doesn't leave the letter dangling.
model AppointmentLetter {
  id                  String                   @id @default(cuid())
  letterCode          String?                  @unique @map("letter_code")

  jobOfferId          String?                  @map("job_offer_id")
  jobOffer            JobOffer?                @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)
  jobApplicationId    String?                  @map("job_application_id")
  jobApplication      JobApplication?          @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)

  applicantName       String                   @map("applicant_name")
  applicantEmail      String?                  @map("applicant_email")
  company             String?

  appointmentDate     DateTime                 @map("appointment_date")
  templateName        String?                  @map("template_name")
  status              AppointmentLetterStatus  @default(DRAFT)

  title               String?
  introduction        String?
  description         String?
  closingNotes        String?                  @map("closing_notes")

  signed              Boolean                  @default(false)
  signedDate          DateTime?                @map("signed_date")

  organizationId      String?                  @map("organization_id")
  organization        Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdById         String?                  @map("created_by_id")
  createdBy           User?                    @relation("AppointmentLetterCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([jobOfferId])
  @@index([jobApplicationId])
  @@index([status])
  @@index([signed])
  @@index([appointmentDate])
  @@index([createdAt])
  @@map("appointment_letters")
}

// Referral submitted by an existing Employee. The referrer is a hard link
// to Employee (you can't refer someone if you don't work here yet); the
// applicant is just a captured snapshot — they don't exist as a User until
// recruitment proper begins.
model EmployeeReferral {
  id                    String                  @id @default(cuid())
  referralCode          String?                 @unique @map("referral_code")

  applicantName         String                  @map("applicant_name")
  applicantEmail        String                  @map("applicant_email")
  applicantMobile       String                  @map("applicant_mobile")
  applicantResumeUrl    String?                 @map("applicant_resume_url")
  applicantResumeName   String?                 @map("applicant_resume_name")

  referralDate          DateTime                @map("referral_date")
  designation           String?

  referringEmployeeId   String                  @map("referring_employee_id")
  referringEmployee     Employee                @relation(fields: [referringEmployeeId], references: [id], onDelete: Cascade)
  referrerFirstName     String                  @map("referrer_first_name")
  referrerDepartment    String?                 @map("referrer_department")

  remark                String?
  status                EmployeeReferralStatus  @default(NEW)

  organizationId        String?                 @map("organization_id")
  organization          Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdById           String?                 @map("created_by_id")
  createdBy             User?                   @relation("EmployeeReferralCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([referringEmployeeId])
  @@index([applicantEmail])
  @@index([status])
  @@index([referralDate])
  @@index([createdAt])
  @@map("employee_referrals")
}

model Activity {
  id             String        @id @default(cuid())
  type           String
  description    String?
  details        Json?
  userId         String        @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  ipAddress      String?       @map("ip_address")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

model PayrollConfiguration {
  id                      String   @id @default(cuid())
  attendanceFormIds       Json     @default("[]") @map("attendance_form_ids")
  leaveFormIds            Json     @default("[]") @map("leave_form_ids")
  attendanceFieldMappings Json     @default("{}") @map("attendance_field_mappings")
  leaveFieldMappings      Json     @default("{}") @map("leave_field_mappings")
  organizationId          String?  @map("organization_id")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([isActive])
  @@map("payroll_configurations")
}

model LeaveType {
  id          String            @id @default(cuid())
  name        String
  code        String            @unique
  category    LeaveTypeCategory
  description String?
  color       String?
  icon        String?
  isActive    Boolean           @default(true) @map("is_active")
  sortOrder   Int               @default(0) @map("sort_order")
  leaveRules  LeaveRule[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@index([sortOrder])
  @@map("leave_types")
}

model LeaveRule {
  id                  String    @id @default(cuid())
  leaveTypeId         String    @map("leave_type_id")
  leaveType           LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  deductionPercentage Decimal   @default(100) @map("deduction_percentage")
  hoursEquivalent     Decimal?  @map("hours_equivalent")
  requiresApproval    Boolean   @default(true) @map("requires_approval")
  maxConsecutiveDays  Int?      @map("max_consecutive_days")
  minNoticeDays       Int?      @map("min_notice_days")
  affectsAttendance   Boolean   @default(true) @map("affects_attendance")
  isPaid              Boolean   @default(false) @map("is_paid")
  carryForward        Boolean   @default(false) @map("carry_forward")
  maxCarryForwardDays Int?      @map("max_carry_forward_days")
  accrualRate         Decimal?  @map("accrual_rate")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([leaveTypeId])
  @@index([isActive])
  @@map("leave_rules")
}

model PayrollRecord {
  id              String    @id @default(cuid())
  employeeId      String    @map("employee_id")
  month           Int
  year            Int
  presentDays     Int       @map("present_days")
  leaveDays       Decimal   @map("leave_days")
  halfDays        Decimal   @default(0) @map("half_days")
  shortLeaves     Int       @default(0) @map("short_leaves")
  overtimeHours   Decimal   @default(0) @map("overtime_hours")
  baseSalary      Decimal   @map("base_salary")
  grossSalary     Decimal   @map("gross_salary")
  deductions      Decimal   @default(0)
  netSalary       Decimal   @map("net_salary")
  allowances      Json      @default("{}")
  deductionDetail Json      @default("{}") @map("deduction_detail")
  status          String    @default("pending")
  processedBy     String?   @map("processed_by")
  processedAt     DateTime? @map("processed_at")
  paidAt          DateTime? @map("paid_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([month])
  @@index([year])
  @@index([status])
  @@map("payroll_records")
}

model Attendance {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  user         User    @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)
  date         String
  checkedIn    Boolean @default(false) @map("checked_in")
  checkedOut   Boolean @default(false) @map("checked_out")
  checkInTime  String? @map("check_in_time")
  checkOutTime String? @map("check_out_time")
  ipAddress    String? @map("ip_address")
  notes        String?

  // Advanced punch metadata. All nullable so existing rows remain valid.
  // checkInAt / checkOutAt are the authoritative timestamps; the legacy
  // checkInTime / checkOutTime strings are kept in sync by the punch
  // service so existing payroll readers keep working without changes.
  organizationId   String?   @map("organization_id")
  checkInAt        DateTime? @map("check_in_at")
  checkOutAt       DateTime? @map("check_out_at")
  checkInLat       Float?    @map("check_in_lat")
  checkInLng       Float?    @map("check_in_lng")
  checkOutLat      Float?    @map("check_out_lat")
  checkOutLng      Float?    @map("check_out_lng")
  checkInIp        String?   @map("check_in_ip")
  checkOutIp       String?   @map("check_out_ip")
  checkInDevice    String?   @map("check_in_device")
  checkOutDevice   String?   @map("check_out_device")
  checkInSource    String?   @map("check_in_source") // WEB | MOBILE | BIOMETRIC | ADMIN
  checkOutSource   String?   @map("check_out_source")
  breakMinutes     Int       @default(0) @map("break_minutes")
  lateMinutes      Int       @default(0) @map("late_minutes")
  earlyOutMinutes  Int       @default(0) @map("early_out_minutes")
  overtimeMinutes  Int       @default(0) @map("overtime_minutes")
  isAutoCheckedOut Boolean   @default(false) @map("is_auto_checked_out")
  status           String? // PRESENT | HALF | ABSENT | ON_LEAVE | HOLIDAY | WEEKLY_OFF | REGULARIZED
  idempotencyKey   String?   @unique @map("idempotency_key")

  // Face-capture proof — public URLs to the photo captured at each punch.
  // Uploaded via /api/attendance/photo through the existing Hostinger
  // uploader. Nullable because face capture is OFF by default and OPTIONAL
  // mode lets users skip on devices without a camera.
  checkInPhoto  String? @map("check_in_photo")
  checkOutPhoto String? @map("check_out_photo")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([checkedIn])
  @@index([checkedOut])
  @@index([organizationId])
  @@index([checkInAt])
  @@map("attendance_records")
}

// One row per organization. Drives shift defaults, geofence, IP whitelist,
// auto-checkout, and the working-day calendar that payroll consumes via
// payroll-store.ts:getPayrollPolicy. Missing row → safe defaults.
model AttendanceConfiguration {
  id             String  @id @default(cuid())
  organizationId String? @unique @map("organization_id")

  // Shift defaults (HH:mm in the org's local timezone).
  defaultShiftStart  String @default("09:00") @map("default_shift_start")
  defaultShiftEnd    String @default("18:00") @map("default_shift_end")
  graceMinutes       Int    @default(15) @map("grace_minutes")
  halfDayMinHours    Float  @default(4) @map("half_day_min_hours")
  fullDayMinHours    Float  @default(8) @map("full_day_min_hours")
  overtimeAfterHours Float  @default(9) @map("overtime_after_hours")
  breakMinutes       Int    @default(60) @map("break_minutes")

  // Working week: 0 = Sun … 6 = Sat. Listed days are WEEKLY-OFF.
  weeklyOffDays Json @default("[0]") @map("weekly_off_days")

  // Auto-checkout (HH:mm). When the nightly worker fires, anyone still
  // checked in is auto-checked-out at this wall time. Empty = disabled.
  autoCheckoutAt String? @map("auto_checkout_at")

  // Geofence enforcement.
  //   OFF      = capture geo only, never block.
  //   CAPTURE  = capture and warn, but allow.
  //   ENFORCE  = reject punches outside the fence.
  geofenceMode    String @default("OFF") @map("geofence_mode")
  geofenceLat     Float? @map("geofence_lat")
  geofenceLng     Float? @map("geofence_lng")
  geofenceRadiusM Int?   @map("geofence_radius_m")

  // IP whitelist. Empty array = no restriction. Any non-empty list means
  // punches from outside these CIDRs are rejected.
  ipWhitelist Json @default("[]") @map("ip_whitelist")

  // Pay-link: which payable-day basis applies. Mirrors PayrollPolicy so the
  // payroll engine can read this single config instead of re-deriving.
  payableBasis String @default("monthDays") @map("payable_basis") // monthDays | fixed26 | fixed30

  // Module name to fire workflow rules under on each successful punch.
  // Empty/null disables workflow integration for attendance. Default
  // "Attendance" matches the conventional FormModule name; admins can
  // change it to "HR" or whatever module hosts their attendance form.
  workflowModuleName String? @default("Attendance") @map("workflow_module_name")

  // Safety: when true, recordPunch refuses to write for a user whose linked
  // Employee row is INACTIVE / TERMINATED / RESIGNED. Off by default so a
  // fresh tenant without Employee rows isn't locked out. Flip on once
  // Employee data is populated.
  enforceEmployeeActive Boolean @default(false) @map("enforce_employee_active")

  // Safety: minimum seconds between consecutive punches by the same user.
  // Set 0 to disable. Idempotent retries (same Idempotency-Key) bypass —
  // this only catches fresh-key spamming.
  minPunchGapSeconds Int @default(5) @map("min_punch_gap_seconds")

  // Face capture: OFF disables the camera entirely; OPTIONAL captures when
  // the device has one but never blocks a punch; REQUIRED gates the punch
  // on a successful capture. Photos are stored as URLs on the Attendance
  // row (checkInPhoto / checkOutPhoto).
  faceCaptureMode String @default("OFF") @map("face_capture_mode") // OFF | OPTIONAL | REQUIRED

  // Hard server-side cap on the uploaded photo size in kilobytes. The
  // browser already downscales aggressively so 800 KB is generous; raise
  // for high-resolution kiosks, lower for cheap data plans.
  facePhotoMaxKb Int @default(800) @map("face_photo_max_kb")

  // The FormModule under which the sidebar should nest the synthetic
  // Attendance leaf. Mirrors PayrollConfiguration's anchor logic so the
  // user sees Attendance live inside their HR module. Null = sidebar
  // omits the link, but the /attendance pages remain reachable directly.
  attendanceModuleId String? @map("attendance_module_id")

  // Per-punch self-notification: when true, every successful check-in /
  // check-out creates a Notification row addressed to the user with the
  // late / overtime breakdown so the bell shows a daily trail.
  notifyOnPunch Boolean @default(true) @map("notify_on_punch")

  // Roles allowed to approve attendance regularizations + use the manual
  // punch endpoint, in addition to admins. Stored as a JSON array of
  // Role.id values. Empty array = admin-only (the historical default).
  attendanceApproverRoleIds Json @default("[]") @map("attendance_approver_role_ids")

  // Scheduled team-attendance report email. Recipients is a JSON array of
  // email addresses; empty/disabled flags skip the send. Timezone is an
  // IANA name (e.g. "Asia/Kolkata") used by the cron scheduler so reports
  // fire at reportSendHour wall-time of the org's timezone — null falls
  // back to the server's TZ.
  reportRecipients      Json    @default("[]") @map("report_recipients")
  reportTimezone        String? @map("report_timezone")
  reportSendHour        Int     @default(7) @map("report_send_hour")
  reportDailyEnabled    Boolean @default(false) @map("report_daily_enabled")
  reportWeeklyEnabled   Boolean @default(false) @map("report_weekly_enabled")
  reportMonthlyEnabled  Boolean @default(false) @map("report_monthly_enabled")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([isActive])
  @@map("attendance_configurations")
}

// Regularization requests — the way users (or admins on their behalf) ask
// to fix a missed / wrong punch on a past day. PENDING rows wait for an
// admin decision; APPROVED rows have already been applied to the
// underlying Attendance row by the service layer.
//
// User / org / attendance references are intentionally plain Strings (no
// @relation) to match the prevailing pattern in this schema and to keep
// the User model untouched.
model AttendanceRegularization {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  userId         String  @map("user_id") // the user whose attendance is being amended
  date           String // YYYY-MM-DD
  attendanceId   String? @map("attendance_id") // null when no row existed for this day yet

  // Snapshot of the row at request time so the reviewer sees what the
  // requester saw, even if the underlying row changes before they review.
  currentCheckInAt    DateTime? @map("current_check_in_at")
  currentCheckOutAt   DateTime? @map("current_check_out_at")
  requestedCheckInAt  DateTime? @map("requested_check_in_at")
  requestedCheckOutAt DateTime? @map("requested_check_out_at")

  reason String @db.Text
  status String @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED

  requestedById String    @map("requested_by_id") // self-request OR admin acting on behalf
  reviewedById  String?   @map("reviewed_by_id")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewNote    String?   @map("review_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([userId, date])
  @@index([status])
  @@index([requestedById])
  @@map("attendance_regularizations")
}

model FormulaField {
  id               String            @id @default(cuid())
  formFieldId      String            @unique
  formField        FormField         @relation(fields: [formFieldId], references: [id], onDelete: Cascade)
  expression       String
  returnType       FormulaReturnType
  autoRefresh      Boolean           @default(true)
  showTooltip      Boolean           @default(false)
  blankPreference  BlankPreference   @default(Empty)
  dependencies     Json              @default("[]")
  lastEvaluatedAt  DateTime?
  evaluationErrors Json?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([formFieldId])
  @@index([autoRefresh])
  @@map("formula_fields")
}

model FormulaFunction {
  id          String            @id @default(cuid())
  name        String            @unique
  description String
  syntax      String
  example     String
  returnType  FormulaReturnType
  args        Json
  isBuiltIn   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("formula_functions")
}

model FormulaOperator {
  id          String   @id @default(cuid())
  symbol      String   @unique
  type        String
  description String
  precedence  Int
  createdAt   DateTime @default(now())

  @@map("formula_operators")
}

model ImportJob {
  id                String               @id @default(cuid())
  fileName          String               @map("file_name")
  fileSize          Int                  @map("file_size")
  fileUrl           String?              @map("file_url")
  moduleId          String               @map("module_id")
  formId            String               @map("form_id")
  status            ImportStatus         @default(PENDING)
  totalRows         Int                  @default(0) @map("total_rows")
  processedRows     Int                  @default(0) @map("processed_rows")
  successRows       Int                  @default(0) @map("success_rows")
  failedRows        Int                  @default(0) @map("failed_rows")
  duplicateHandling DuplicateHandling    @default(INSERT_ONLY) @map("duplicate_handling")
  enableWorkflows   Boolean              @default(false) @map("enable_workflows")
  enableValidation  Boolean              @default(true) @map("enable_validation")
  enableApprovals   Boolean              @default(false) @map("enable_approvals")
  errorFileUrl      String?              @map("error_file_url")
  startedAt         DateTime?            @map("started_at")
  completedAt       DateTime?            @map("completed_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  mappings          ImportFieldMapping[]
  rows              ImportRow[]

  @@index([moduleId])
  @@index([formId])
  @@index([status])
  @@index([createdAt])
  @@map("import_jobs")
}

model ImportFieldMapping {
  id                  String    @id @default(cuid())
  importJobId         String    @map("import_job_id")
  importJob           ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  sourceColumn        String    @map("source_column")
  targetFieldId       String    @map("target_field_id")
  lookupResolutionKey String?   @map("lookup_resolution_key")
  transformationRules Json?     @map("transformation_rules")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([importJobId])
  @@index([targetFieldId])
  @@map("import_field_mappings")
}

model ImportRow {
  id           String    @id @default(cuid())
  importJobId  String    @map("import_job_id")
  importJob    ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber    Int       @map("row_number")
  rawData      Json      @map("raw_data")
  status       String
  errorMessage String?   @map("error_message")
  recordId     String?   @map("record_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([importJobId])
  @@index([status])
  @@index([rowNumber])
  @@map("import_rows")
}

model ExportJob {
  id               String       @id @default(cuid())
  moduleId         String       @map("module_id")
  formId           String       @map("form_id")
  format           ExportFormat @default(CSV)
  selectedFields   Json         @map("selected_fields")
  filters          Json?
  status           ImportStatus @default(PENDING)
  totalRecords     Int          @default(0) @map("total_records")
  processedRecords Int          @default(0) @map("processed_records")
  fileUrl          String?      @map("file_url")
  startedAt        DateTime?    @map("started_at")
  completedAt      DateTime?    @map("completed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([moduleId])
  @@index([formId])
  @@index([status])
  @@index([createdAt])
  @@map("export_jobs")
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    String?
  email     String
  ipAddress String?
  userAgent String?
  status    String // "Success" or "Failed"
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("login_history")
}

model AuditLog {
  id     String  @id @default(cuid())
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // NEW: Organization ID for multi-tenant isolation
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  performedBy String // Email of the person who performed the action
  action      String
  module      String
  recordId    String?  @map("record_id")
  recordName  String?  @map("record_name")
  details     String?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([organizationId])
  @@index([performedBy])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@index([ipAddress])
  @@map("audit_logs")
}

model UniqueIdCounter {
  id         String   @id @default(cuid())
  fieldId    String   @unique
  lastNumber BigInt   @default(0) // Using BigInt → supports much larger sequences
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([fieldId])
  @@map("unique_id_counters")
}

// ═══════════════════════════════════════════════════════════════════════════════
// UNIFIED FORM RECORD (replaces 15 sharded tables)
// ═══════════════════════════════════════════════════════════════════════════════

model FormRecord {
  id             String            @id @default(cuid())
  formId         String            @map("form_id")
  form           Form              @relation("FormRecords", fields: [formId], references: [id], onDelete: Cascade)
  recordData     Json              @default("{}") @map("record_data")
  organizationId String?           @map("organization_id")
  employee_id    String?
  amount         Decimal?
  date           DateTime?
  submittedBy    String?           @map("submitted_by")
  submittedAt    DateTime          @default(now()) @map("submitted_at")
  ipAddress      String?           @map("ip_address")
  userAgent      String?           @map("user_agent")
  status         String            @default("submitted")
  userId         String?           @map("user_id")
  user           User?             @relation("FormRecordUser", fields: [userId], references: [id], onDelete: SetNull)
  indexedFields  FormRecordField[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([formId])
  @@index([organizationId])
  @@index([submittedAt])
  @@index([status])
  @@index([employee_id])
  @@index([date])
  @@index([userId])
  @@map("form_records")
}

model FormRecordField {
  id              String     @id @default(cuid())
  recordId        String     @map("record_id")
  record          FormRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  formId          String     @map("form_id")
  fieldId         String     @map("field_id")
  subformId       String?    @map("subform_id")
  subformRowIndex Int?       @map("subform_row_index")
  value_text      String?
  value_number    Decimal?
  value_date      DateTime?
  value_bool      Boolean?
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([formId, fieldId, value_text])
  @@index([formId, fieldId, value_number])
  @@index([formId, fieldId, value_date])
  @@index([formId, fieldId, value_bool])
  @@index([recordId])
  @@index([formId, subformId, subformRowIndex])
  @@map("form_record_fields")
}

model RoutePermission {
  id             String            @id @default(cuid())
  pattern        String
  description    String?
  redirectTo     String?           @map("redirect_to")
  organizationId String            @map("organization_id")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleAccess     RouteRoleAccess[]
  userAccess     RouteUserAccess[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@unique([pattern, organizationId])
  @@index([organizationId])
  @@map("route_permissions")
}

model RouteRoleAccess {
  id                String          @id @default(cuid())
  routePermissionId String          @map("route_permission_id")
  routePermission   RoutePermission @relation(fields: [routePermissionId], references: [id], onDelete: Cascade)
  roleId            String          @map("role_id")
  role              Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  granted           Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([routePermissionId, roleId])
  @@index([routePermissionId])
  @@index([roleId])
  @@map("route_role_access")
}

model RouteUserAccess {
  id                String          @id @default(cuid())
  routePermissionId String          @map("route_permission_id")
  routePermission   RoutePermission @relation(fields: [routePermissionId], references: [id], onDelete: Cascade)
  userId            String          @map("user_id")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  granted           Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([routePermissionId, userId])
  @@index([routePermissionId])
  @@index([userId])
  @@map("route_user_access")
}

model SavedFilter {
  id             String       @id @default(cuid())
  name           String
  moduleId       String       @map("module_id")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String       @map("created_by_id")
  createdBy      User         @relation("SavedFilterCreator", fields: [createdById], references: [id], onDelete: Cascade)
  filters        Json // Array of FieldFilter objects
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([createdById])
  @@index([moduleId])
  @@map("saved_filters")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI / Chatbot — cloud provider registry with multi-key rotation
// Design: OpenAI-compatible upstream only. Providers speak POST /v1/chat/completions.
// Keys are AES-256-GCM encrypted at rest; rotator lives in-process (swap for Redis later).
// ─────────────────────────────────────────────────────────────────────────────

model AIProvider {
  id              String          @id @default(cuid())
  organizationId  String          @map("organization_id")
  name            String // slug: "openai", "groq", "openrouter", "anthropic", "gemini", "together", "deepinfra", "custom"
  displayName     String          @map("display_name")
  baseUrl         String          @map("base_url")
  defaultModel    String          @map("default_model")
  availableModels Json            @default("[]") @map("available_models")
  isActive        Boolean         @default(true) @map("is_active")
  isDefault       Boolean         @default(false) @map("is_default")
  priority        Int             @default(0)
  temperature     Float?          @default(0.7)
  maxTokens       Int?            @map("max_tokens")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  apiKeys         AIProviderKey[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isActive])
  @@index([isDefault])
  @@map("ai_providers")
}

model AIProviderKey {
  id             String     @id @default(cuid())
  providerId     String     @map("provider_id")
  provider       AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  organizationId String     @map("organization_id")
  label          String
  encryptedKey   String     @map("encrypted_key")
  keyPreview     String     @map("key_preview")
  isActive       Boolean    @default(true) @map("is_active")
  lastUsedAt     DateTime?  @map("last_used_at")
  failureCount   Int        @default(0) @map("failure_count")
  cooldownUntil  DateTime?  @map("cooldown_until")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([providerId])
  @@index([organizationId])
  @@index([isActive])
  @@map("ai_provider_keys")
}

model ChatConversation {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String        @map("organization_id")
  title          String        @default("New chat")
  providerId     String?       @map("provider_id")
  model          String?
  systemPrompt   String?       @map("system_prompt")
  temperature    Float?
  isPinned       Boolean       @default(false) @map("is_pinned")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  messages       ChatMessage[]

  @@index([userId])
  @@index([organizationId])
  @@index([updatedAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String           @map("conversation_id")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "system" | "user" | "assistant"
  content        String
  providerName   String?          @map("provider_name")
  model          String?
  tokensIn       Int?             @map("tokens_in")
  tokensOut      Int?             @map("tokens_out")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Workflow Rules — automation rules triggered by record actions or date fields
// ─────────────────────────────────────────────────────────────────────────────

model WorkflowRule {
  id                String              @id @default(cuid())
  name              String
  description       String?
  moduleName        String              @map("module_name")
  executeBasedOn    String              @map("execute_based_on") // "record-action" | "record-field" | "schedule"
  recordAction      String?             @map("record_action") // "Create" | "Create or Edit" | "Edit" | "Delete"
  dateField         String?             @map("date_field") // "Created Time" | "Last Activity Time" etc.
  conditionType     String              @default("all") @map("condition_type") // "all" | "matching"
  conditions        Json? // Array of condition objects
  instantActions    Json?               @map("instant_actions") // Array of selected instant action names
  scheduledExecute  String?             @map("scheduled_execute") // Number value (legacy: delay-after-date-field)
  scheduledUnit     String?             @map("scheduled_unit") // "Minutes" | "Hours" | "Days"
  // ── Schedule trigger fields (executeBasedOn = "schedule") ─────────────────
  scheduleCadence   String?             @map("schedule_cadence") // "daily" | "weekly" | "monthly" | "custom"
  scheduleCron      String?             @map("schedule_cron") // raw cron expression when cadence = "custom"
  scheduleHour      Int?                @map("schedule_hour") // 0-23, used by daily/weekly/monthly
  scheduleMinute    Int?                @default(0) @map("schedule_minute") // 0-59
  scheduleDayOfWeek Int?                @map("schedule_day_of_week") // 0=Sun..6=Sat, weekly only
  scheduleDayOfMonth Int?               @map("schedule_day_of_month") // 1-31, monthly only
  scheduleTimezone  String?             @map("schedule_timezone") // IANA tz, e.g. "Asia/Kolkata"
  scheduleEnabled   Boolean             @default(true) @map("schedule_enabled")
  active            Boolean             @default(true)
  organizationId    String              @map("organization_id")
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById       String              @map("created_by_id")
  createdBy         User                @relation("WorkflowRuleCreator", fields: [createdById], references: [id], onDelete: Cascade)
  executions        WorkflowExecution[]
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([createdById])
  @@index([moduleName])
  @@index([executeBasedOn, active])
  @@map("workflow_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// Workflow Executions — audit log of every rule firing (scheduled or event)
// ─────────────────────────────────────────────────────────────────────────────

model WorkflowExecution {
  id             String       @id @default(cuid())
  ruleId         String       @map("rule_id")
  rule           WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trigger        String // "schedule" | "manual" | "record-create" | "record-edit" | "record-delete"
  status         String // "success" | "partial" | "failed" | "skipped"
  startedAt      DateTime     @default(now()) @map("started_at")
  finishedAt     DateTime?    @map("finished_at")
  durationMs     Int?         @map("duration_ms")
  actionsRun     Int          @default(0) @map("actions_run")
  recipientCount Int?         @map("recipient_count")
  error          String?      @db.Text
  details        Json? // per-action results, recipient lists, etc.

  @@index([ruleId, startedAt])
  @@index([organizationId, startedAt])
  @@map("workflow_executions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Functions — custom scripts that can be associated to automation features
// ─────────────────────────────────────────────────────────────────────────────

model CrmFunction {
  id             String            @id @default(cuid())
  name           String
  displayName    String            @map("display_name")
  category       String            @default("Automation")
  language       String            @default("JavaScript")
  description    String?
  associated     Boolean           @default(false)
  restApi        Boolean           @default(false) @map("rest_api")
  script         String?           @db.Text
  organizationId String            @map("organization_id")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String            @map("created_by_id")
  createdBy      User              @relation("CrmFunctionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  bindings       FunctionBinding[]
  executions     FunctionExecution[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([createdById])
  @@index([category])
  @@map("crm_functions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Function executions — audit log for every script run (manual test, workflow
// rule, scheduled trigger, binding event). Powers the /settings/functions/
// executions page and the per-function "View Logs" panel.
// ─────────────────────────────────────────────────────────────────────────────
model FunctionExecution {
  id             String       @id @default(cuid())
  functionId     String       @map("function_id")
  function       CrmFunction  @relation(fields: [functionId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trigger        String // "manual" | "test" | "workflow" | "scheduled" | "binding" | "rest-api"
  status         String // "success" | "failed"
  startedAt      DateTime     @default(now()) @map("started_at")
  finishedAt     DateTime?    @map("finished_at")
  durationMs     Int?         @map("duration_ms")
  input          Json?
  result         Json?
  // Console output captured during the run — array of { level, args, ts }.
  // Stored as Json so the log viewer can render with colour coding.
  logs           Json?
  error          String?      @db.Text
  // Acting user — null for fully autonomous runs (e.g. scheduled with no
  // session). Resolves via the User relation for display.
  userId         String?      @map("user_id")
  user           User?        @relation("FunctionExecutionActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([functionId, startedAt])
  @@index([organizationId, startedAt])
  @@map("function_executions")
}

// Connects a CrmFunction to a Form / FormField / FormModule with a trigger
// event and JSON I/O mapping. Lets one script be reused across many forms
// without baking form-specific field IDs into the script body.
model FunctionBinding {
  id         String      @id @default(cuid())
  functionId String      @map("function_id")
  function   CrmFunction @relation(fields: [functionId], references: [id], onDelete: Cascade)

  // Scope — exactly one of these is set (enforced at app layer)
  formId   String?     @map("form_id")
  form     Form?       @relation(fields: [formId], references: [id], onDelete: Cascade)
  fieldId  String?     @map("field_id")
  field    FormField?  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  moduleId String?     @map("module_id")
  module   FormModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // "onFieldChange" | "onFieldBlur" | "beforeSubmit" | "afterCreate" | "afterUpdate" | "manual"
  event          String
  inputMapping   Json         @default("{}") @map("input_mapping")
  outputMapping  Json         @default("{}") @map("output_mapping")
  condition      Json?
  active         Boolean      @default(true)
  order          Int          @default(0)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([functionId])
  @@index([formId])
  @@index([fieldId])
  @@index([moduleId])
  @@index([event])
  @@index([organizationId])
  @@map("function_bindings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications — in-app system notifications fanned out to recipients by the
// "System Notification" workflow action. One row per (recipient, event); the
// bell in the sidebar reads from this table and marks rows read on click.
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id             String       @id @default(cuid())
  recipientId    String       @map("recipient_id")
  recipient      User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Display content. Both rendered server-side from the rule's templates so the
  // bell can show them as-is without needing to re-resolve field values.
  title String
  body  String? @db.Text

  // Origin metadata — useful for "View record" links and audit trails.
  ruleId     String? @map("rule_id")
  ruleName   String? @map("rule_name")
  moduleName String? @map("module_name")
  formId     String? @map("form_id")
  recordId   String? @map("record_id")
  link       String? // optional deep link the bell can navigate to

  // Structured payload — currently `{ fields: [{ label, apiName, value }] }`
  // populated by the System Notification action so the bell's detail popup
  // can render the admin-selected fields as a clean table instead of an
  // appended text blob.
  data Json?

  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([recipientId, isRead, createdAt])
  @@index([organizationId, createdAt])
  @@index([ruleId])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// Leave Management — real, schema-backed leave requests, balances, and a
// holiday calendar. Replaces the form-based "leaves are FormRecords" approach
// while keeping the old reader as a fallback in payroll-store so existing
// tenants don't break.
//
// User / org / leaveType references are plain Strings (no @relation) to match
// the prevailing pattern (see AttendanceRegularization) and keep the User
// model untouched. The service layer (lib/hr/leave-service.ts) does the joins.
// ─────────────────────────────────────────────────────────────────────────────

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveDuration {
  FULL_DAY
  HALF_DAY_FIRST // first half of the day (morning)
  HALF_DAY_SECOND // second half of the day (afternoon)
}

model LeaveRequest {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id") // applicant
  leaveTypeId    String @map("leave_type_id")

  // YYYY-MM-DD strings, inclusive on both ends. Matches Attendance.date so
  // the leave/attendance/payroll readers can compare with simple string ops.
  startDate String @map("start_date")
  endDate   String @map("end_date")

  duration  LeaveDuration @default(FULL_DAY)
  totalDays Decimal       @map("total_days") // computed at apply time, excludes weekly-off + holidays

  reason        String? @db.Text
  attachmentUrl String? @map("attachment_url")

  status       LeaveRequestStatus @default(PENDING)
  appliedAt    DateTime           @default(now()) @map("applied_at")
  decidedAt    DateTime?          @map("decided_at")
  decidedById  String?            @map("decided_by_id")
  decisionNote String?            @map("decision_note") @db.Text
  cancelledAt  DateTime?          @map("cancelled_at")
  cancelReason String?            @map("cancel_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([leaveTypeId])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// One row per (user, leaveType, year). Running counters; the source of truth
// for "how many days do I have left this year".
model LeaveBalance {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  leaveTypeId    String @map("leave_type_id")
  year           Int

  allocated      Decimal @default(0) // base allocation (admin-set or accrual)
  carriedForward Decimal @default(0) @map("carried_forward")
  used           Decimal @default(0) // sum of APPROVED totalDays
  pending        Decimal @default(0) // sum of PENDING totalDays (soft-hold)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, leaveTypeId, year])
  @@index([organizationId, year])
  @@map("leave_balances")
}

// Audit trail for every balance mutation. Lets admins answer "why does this
// employee have N leaves left?" by walking back through deltas.
//   reason: 'INITIAL' | 'CARRY_FORWARD' | 'APPROVED' | 'CANCELLED' | 'REJECTED' | 'ADMIN_ADJUST'
model LeaveAllocation {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  leaveTypeId    String @map("leave_type_id")
  year           Int

  delta       Decimal // signed: +5 (grant), -1 (consume), -1.5 (consume), +1.5 (refund)
  reason      String
  referenceId String? @map("reference_id") // LeaveRequest.id when reason ties to a request
  note        String? @db.Text
  createdById String  @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, userId, year])
  @@index([referenceId])
  @@map("leave_allocations")
}

// Holiday calendar — replaces the "holidays live in a generic form" pattern.
// Read by both the attendance widget (shows HOLIDAY badge + skips punch
// requirement) and payroll (counts holidays as paid days). Form-based reader
// remains as fallback in payroll-store.
model Holiday {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  date           String // YYYY-MM-DD
  name           String
  isOptional     Boolean  @default(false) @map("is_optional")
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, date])
  @@index([organizationId])
  @@map("holidays")
}

// Anchors a static page (URL listed in lib/static-pages.ts) under a dynamic
// FormModule so the sidebar nests it there. Two row "kinds" share this table,
// distinguished by the path value:
//   - Page anchor:  `path` is one of the known static-page paths (e.g. "/leave").
//   - Group anchor: `path` is `group:<GroupName>` (e.g. "group:Attendance"),
//                   meaning ALL pages in that group inherit this module unless
//                   a specific page anchor overrides.
// `moduleId` references FormModule.id at the application layer; we don't add a
// formal FK because page anchors should keep working if a module is renamed
// at app-level (the API rejects orphaned ids on save). Resolution chain in
// app/api/static-page-anchors/route.ts: page > group > attendance-config-derived.
model StaticPageAnchor {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  path           String // page path or "group:<GroupName>"
  moduleId       String   @map("module_id")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, path])
  @@index([organizationId])
  @@index([moduleId])
  @@map("static_page_anchors")
}

// Recycle Bin — every soft-delete in the app drops a snapshot here. The
// `snapshot` JSON is a self-contained tree (record + children) so a restore
// can rebuild the original transactionally without depending on cascade
// records still living elsewhere. `resourceType` keys into the handler
// registry in lib/trash/handlers.ts.
model TrashBin {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  resourceType   String   @map("resource_type") // "Form" | "FormModule" | "Holiday" | ...
  resourceId     String   @map("resource_id")   // original record id (for re-create)
  resourceName   String?  @map("resource_name") // human-readable label for the trash list
  snapshot       Json
  deletedById    String?  @map("deleted_by_id")
  deletedByName  String?  @map("deleted_by_name")
  deletedAt      DateTime @default(now()) @map("deleted_at")

  @@index([organizationId, deletedAt])
  @@index([resourceType])
  @@index([resourceId])
  @@map("trash_bin")
}

// Per-org retention policy for the recycle bin. Items in TrashBin older than
// `retentionDays` get purged on the next read of /api/trash. Set to 0 to
// disable auto-purge ("Never" — items live in trash until manually deleted).
// 1:1 with Organization; created on first read with default 30 days.
model TrashRetentionSetting {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")
  retentionDays  Int      @default(30) @map("retention_days")
  updatedById    String?  @map("updated_by_id")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("trash_retention_settings")
}

// ═══════════════════════════════════════════════════════════════════════════════
// REAL ESTATE BROKERAGE MANAGEMENT (REBM) — Phase 1
// Module #2 of the ERP. Covers Property inventory, Agent hierarchy (MLM tree),
// and Lead/CRM pipeline with viewings. Commission engine, wallets, payouts and
// compliance follow in later phases.
//
// Conventions (match the rest of the schema):
//   - User / Organization references are stored as plain Strings (no @relation)
//     to mirror LeaveRequest / AttendanceRegularization. Service layer joins.
//   - Strong ownership relations (Property → images / docs, Lead → activities)
//     keep @relation for cascade delete.
//   - Decimal money fields use @db.Decimal(14,2); percent fields use (7,4).
//   - All tables prefixed `re_` for clear namespacing within the database.
// ═══════════════════════════════════════════════════════════════════════════════

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  INDUSTRIAL
  AGRICULTURAL
}

enum PropertySubType {
  APARTMENT
  VILLA
  HOUSE
  TOWNHOUSE
  STUDIO
  PENTHOUSE
  OFFICE
  RETAIL
  WAREHOUSE
  HOTEL
  PLOT
  FARM
  OTHER
}

enum PropertyStatus {
  DRAFT
  AVAILABLE
  UNDER_CONTRACT
  SOLD
  WITHDRAWN
  EXPIRED
}

enum PropertyDocumentType {
  TITLE_DEED
  NOC
  FLOOR_PLAN
  TAX_RECEIPT
  AGREEMENT
  POSSESSION_LETTER
  OTHER
}

enum CommissionTermType {
  PERCENTAGE
  FLAT_FEE
}

model Property {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")

  // Identity
  title       String
  code        String? // optional human-readable code, e.g. "PROP-2026-0042"
  description String? @db.Text

  // Classification
  type    PropertyType
  subType PropertySubType? @map("sub_type")
  status  PropertyStatus   @default(DRAFT)

  // Location
  addressLine1 String   @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  city         String
  state        String?
  country      String
  postalCode   String?  @map("postal_code")
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)

  // Pricing & area
  listingPrice Decimal  @map("listing_price") @db.Decimal(14, 2)
  currency     String   @default("INR")
  area         Decimal? @db.Decimal(12, 2)
  areaUnit     String?  @map("area_unit") // sqft, sqm, acre, hectare
  bedrooms     Int?
  bathrooms    Int?
  parkingSpots Int?     @map("parking_spots")
  yearBuilt    Int?     @map("year_built")

  // Free-form features bag — ["pool","gym","gated"]
  features Json @default("[]")

  // Commission terms (FR-1.7)
  commissionTermType   CommissionTermType @default(PERCENTAGE) @map("commission_term_type")
  commissionPercentage Decimal?           @map("commission_percentage") @db.Decimal(7, 4)
  commissionFlatFee    Decimal?           @map("commission_flat_fee") @db.Decimal(14, 2)

  // Listing dates
  listedAt          DateTime  @default(now()) @map("listed_at")
  expectedClosingAt DateTime? @map("expected_closing_at")
  finalClosingAt    DateTime? @map("final_closing_at")
  expiresAt         DateTime? @map("expires_at")

  // Listing agent (FR-1.10) — User.id, plain String (service layer joins)
  listingAgentId String @map("listing_agent_id")

  // Constraint per BR-12 — minimum acceptable closing % of listing price
  minClosingPercent Decimal? @map("min_closing_percent") @db.Decimal(5, 2)

  // Denormalised primary image URL for fast list-page rendering
  primaryImageUrl String? @map("primary_image_url")

  images       PropertyImage[]
  documents    PropertyDocument[]
  priceHistory PropertyPriceHistory[]
  viewings     PropertyViewing[]
  transactions Transaction[]

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([organizationId, type, subType])
  @@index([city, country])
  @@index([listingAgentId])
  @@index([listingPrice])
  @@map("re_properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([propertyId, sortOrder])
  @@map("re_property_images")
}

model PropertyDocument {
  id           String               @id @default(cuid())
  propertyId   String               @map("property_id")
  property     Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type         PropertyDocumentType
  name         String
  url          String
  verifiedAt   DateTime?            @map("verified_at")
  verifiedById String?              @map("verified_by_id") // → User.id
  uploadedById String               @map("uploaded_by_id") // → User.id
  createdAt    DateTime             @default(now()) @map("created_at")

  @@index([propertyId])
  @@index([type])
  @@map("re_property_documents")
}

model PropertyPriceHistory {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  oldPrice    Decimal  @map("old_price") @db.Decimal(14, 2)
  newPrice    Decimal  @map("new_price") @db.Decimal(14, 2)
  changedById String   @map("changed_by_id") // → User.id
  reason      String?
  changedAt   DateTime @default(now()) @map("changed_at")

  @@index([propertyId, changedAt])
  @@map("re_property_price_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENT HIERARCHY (MLM tree)
// ─────────────────────────────────────────────────────────────────────────────

enum AgentStatus {
  PENDING_KYC
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum AgentComplianceStatus {
  COMPLIANT
  PENDING_KYC
  NON_COMPLIANT
}

model Rank {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  code           String // unique within org, e.g. TRAINEE / ASSOCIATE / MD
  description    String?
  level          Int     @default(0) // higher = more senior

  // Promotion criteria — auto-evaluated; manual override permitted
  minPersonalSales     Int?     @map("min_personal_sales")
  minTeamSize          Int?     @map("min_team_size")
  minTeamRevenue       Decimal? @map("min_team_revenue") @db.Decimal(16, 2)
  evaluationWindowDays Int?     @map("evaluation_window_days") // null = lifetime

  // Override percents by tree depth, e.g. [5, 3, 1]. Stored as Json so depth
  // can be re-tuned without a schema change.
  overridePercents Json @default("[]") @map("override_percents")

  // Optional rank-up bonus credited to wallet on promotion
  rankUpBonus Decimal? @map("rank_up_bonus") @db.Decimal(14, 2)

  // Optional team-sales multiplier (e.g. MD earns extra on team revenue)
  teamBonusPercent Decimal? @map("team_bonus_percent") @db.Decimal(7, 4)

  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agents AgentProfile[]

  @@unique([organizationId, code])
  @@index([organizationId, level])
  @@map("re_ranks")
}

model AgentProfile {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  userId         String @unique @map("user_id")
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional employee link — Section 3.1 (agent may also be HR employee)
  employeeId String? @unique @map("employee_id")

  // MLM tree (FR-2.1, FR-2.2)
  sponsorId String?        @map("sponsor_id")
  sponsor   AgentProfile?  @relation("AgentSponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  recruits  AgentProfile[] @relation("AgentSponsor")

  parentId String?        @map("parent_id")
  parent   AgentProfile?  @relation("AgentParent", fields: [parentId], references: [id], onDelete: SetNull)
  children AgentProfile[] @relation("AgentParent")

  // Sponsor code — shareable handle that lets recruits self-onboard into tree
  sponsorCode String? @unique @map("sponsor_code")

  // Rank
  rankId         String?   @map("rank_id")
  rank           Rank?     @relation(fields: [rankId], references: [id], onDelete: SetNull)
  rankAssignedAt DateTime? @map("rank_assigned_at")

  // Status & compliance
  status           AgentStatus           @default(PENDING_KYC)
  complianceStatus AgentComplianceStatus @default(PENDING_KYC) @map("compliance_status")

  // License (FR-8)
  licenseNumber    String?   @map("license_number")
  licenseAuthority String?   @map("license_authority")
  licenseIssuedAt  DateTime? @map("license_issued_at")
  licenseExpiresAt DateTime? @map("license_expires_at")

  // Lifecycle
  joinedAt         DateTime  @default(now()) @map("joined_at")
  suspendedAt      DateTime? @map("suspended_at")
  terminatedAt     DateTime? @map("terminated_at")
  suspensionReason String?   @map("suspension_reason")

  // Profile fields
  specializations Json    @default("[]") // ["RESIDENTIAL","COMMERCIAL"]
  serviceAreas    Json    @default("[]") @map("service_areas") // ["Mumbai","Pune"]
  bio             String? @db.Text

  promotions          RankPromotionLog[]
  complianceDocuments ComplianceDocument[]
  reraProfile         AgentReraProfile?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([sponsorId])
  @@index([parentId])
  @@index([rankId])
  @@index([licenseExpiresAt])
  @@map("re_agent_profiles")
}

model RankPromotionLog {
  id           String       @id @default(cuid())
  agentId      String       @map("agent_id")
  agent        AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  fromRankId   String?      @map("from_rank_id")
  toRankId     String       @map("to_rank_id")
  triggeredBy  String       @map("triggered_by") // 'SYSTEM' | 'MANUAL'
  approvedById String?      @map("approved_by_id") // → User.id
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([agentId, createdAt])
  @@map("re_rank_promotions")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEADS / CRM
// ─────────────────────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VIEWING_SCHEDULED
  NEGOTIATING
  CONVERTED
  LOST
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WALK_IN
  PORTAL
  SOCIAL
  CAMPAIGN
  WEBHOOK
  OTHER
}

enum LeadActivityType {
  CALL
  EMAIL
  MEETING
  VIEWING
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
}

enum ViewingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Lead {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  // Contact
  name     String
  email    String?
  phone    String?
  altPhone String? @map("alt_phone")

  // Interest profile
  budgetMin       Decimal? @map("budget_min") @db.Decimal(14, 2)
  budgetMax       Decimal? @map("budget_max") @db.Decimal(14, 2)
  preferredCities Json     @default("[]") @map("preferred_cities")
  propertyTypes   Json     @default("[]") @map("property_types") // ["RESIDENTIAL"]
  bedroomsMin     Int?     @map("bedrooms_min")

  // Pipeline (FR-3.2)
  status        LeadStatus @default(NEW)
  score         LeadScore  @default(WARM)
  source        LeadSource @default(OTHER)
  sourceDetails String?    @map("source_details")

  // Assignment
  assignedAgentId String?   @map("assigned_agent_id") // → User.id
  assignedAt      DateTime? @map("assigned_at")

  // Follow-up (FR-3.7)
  nextFollowUpAt  DateTime? @map("next_follow_up_at")
  lastContactedAt DateTime? @map("last_contacted_at")

  // Conversion (FR-3.8 / BR-13)
  convertedAt DateTime? @map("converted_at")
  buyerId     String?   @unique @map("buyer_id")
  buyer       Buyer?    @relation(fields: [buyerId], references: [id])
  lostReason  String?   @map("lost_reason")

  notes      String? @db.Text
  activities LeadActivity[]
  viewings   PropertyViewing[]

  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([assignedAgentId, status])
  @@index([nextFollowUpAt])
  @@index([score])
  @@map("re_leads")
}

model LeadActivity {
  id         String           @id @default(cuid())
  leadId     String           @map("lead_id")
  lead       Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       LeadActivityType
  agentId    String           @map("agent_id") // → User.id
  occurredAt DateTime         @default(now()) @map("occurred_at")
  subject    String?
  content    String?          @db.Text
  outcome    String?
  // Type-specific payload, e.g. { fromStatus, toStatus } or
  // { fromAgentId, toAgentId } for ASSIGNMENT
  data Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId, occurredAt])
  @@index([agentId, occurredAt])
  @@map("re_lead_activities")
}

model PropertyViewing {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  leadId         String        @map("lead_id")
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId     String        @map("property_id")
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agentId        String        @map("agent_id") // → User.id
  scheduledAt    DateTime      @map("scheduled_at")
  durationMin    Int           @default(30) @map("duration_min")
  status         ViewingStatus @default(SCHEDULED)
  feedback       String?       @db.Text
  outcomeRating  Int?          @map("outcome_rating") // 1–5

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, scheduledAt])
  @@index([propertyId, scheduledAt])
  @@index([agentId, scheduledAt])
  @@index([leadId])
  @@map("re_property_viewings")
}

// Confirmed customer once a lead converts. Separated from Lead so future
// Transaction / Payment / Agreement entities can attach without polluting the
// CRM-side tables.
model Buyer {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  email          String?
  phone          String?
  panOrTaxId     String? @map("pan_or_tax_id") // sensitive — masked in UI
  addressLine1   String? @map("address_line_1")
  city           String?
  country        String?

  lead         Lead? // back-ref via Lead.buyerId
  transactions Transaction[]

  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([email])
  @@index([phone])
  @@map("re_buyers")
}

// ═══════════════════════════════════════════════════════════════════════════════
// REBM Phase 2 — Transactions, Commission Engine, Wallets/Ledger, Payouts
// FR-4, FR-5, FR-6, FR-7
// ═══════════════════════════════════════════════════════════════════════════════

enum TransactionStatus {
  PENDING
  CLOSED
  CANCELLED
  DISPUTED
}

enum TransactionDocumentType {
  CONTRACT
  SALE_DEED
  PAYMENT_PROOF
  KYC
  OTHER
}

// A property sale. FR-4. The commission engine fires on transition to CLOSED
// and reverses on subsequent CANCELLED.
model Transaction {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  code String? // optional human-readable code, e.g. TXN-2026-0007

  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id])

  buyerId String? @map("buyer_id")
  buyer   Buyer?  @relation(fields: [buyerId], references: [id])

  // Listing & selling agents may be the same User (FR-4.3). Plain Strings
  // (User.id) per the prevailing pattern; service layer joins.
  listingAgentId String  @map("listing_agent_id")
  sellingAgentId String? @map("selling_agent_id")

  // Pricing (Decimal for safety; FR-5.8)
  salePrice  Decimal @map("sale_price") @db.Decimal(14, 2)
  currency   String  @default("INR")

  // Lifecycle
  status     TransactionStatus @default(PENDING)
  closedAt   DateTime?         @map("closed_at")
  cancelledAt DateTime?        @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  // Versioning — once closed, the transaction "owns" the rule it used (FR-5.11
  // / BR-9). The application layer stamps these at close time.
  commissionRuleId      String?  @map("commission_rule_id")
  commissionRuleVersion Int?     @map("commission_rule_version")

  // Total commission produced by the engine. Sum of CommissionSplit.amount.
  baseCommission Decimal? @map("base_commission") @db.Decimal(14, 2)

  // Payment terms — free-form for Phase 2; later iterations may model EMIs.
  paymentTerms String? @map("payment_terms") @db.Text

  documents     TransactionDocument[]
  commissionSplits CommissionSplit[]
  commissionAudits CommissionAudit[]
  ledgerEntries LedgerEntry[]

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([propertyId])
  @@index([buyerId])
  @@index([listingAgentId])
  @@index([sellingAgentId])
  @@index([closedAt])
  @@map("re_transactions")
}

model TransactionDocument {
  id            String                  @id @default(cuid())
  transactionId String                  @map("transaction_id")
  transaction   Transaction             @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  type          TransactionDocumentType
  name          String
  url           String
  uploadedById  String                  @map("uploaded_by_id")
  createdAt     DateTime                @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([type])
  @@map("re_transaction_documents")
}

// Versioned, configurable commission rule. FR-5.11 — once a transaction
// closes against a (rule, version), that pair is frozen on the transaction
// row, so future edits don't disturb history.
model CommissionRule {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  description    String?

  // Optional scope. When propertyType is set, the rule only matches that
  // type. Null = applies to all types as a fallback.
  propertyType PropertyType? @map("property_type")

  // The current active version is the row with isActive=true and the highest
  // version number. We never mutate rules in place — a "save" creates a new
  // CommissionRule row with version+1 and flips the previous one inactive.
  version  Int     @default(1)
  isActive Boolean @default(true) @map("is_active")

  // Splits, % of base. FR-5.3 — must sum to 100.
  listingAgentPercent Decimal @map("listing_agent_percent") @db.Decimal(7, 4)
  sellingAgentPercent Decimal @map("selling_agent_percent") @db.Decimal(7, 4)
  brokeragePercent    Decimal @map("brokerage_percent") @db.Decimal(7, 4)

  // Override percents by tree depth (taken FROM the brokerage share).
  // Same shape as Rank.overridePercents; rules can declare their own ladder
  // or fall through to the agent's rank.overridePercents (controlled by
  // useRankOverrides). Stored as Json (decimal array).
  overridePercents  Json    @default("[]") @map("override_percents")
  useRankOverrides  Boolean @default(false) @map("use_rank_overrides")
  maxOverrideDepth  Int     @default(3) @map("max_override_depth")

  // Default base commission = % of sale price for any property that doesn't
  // override on the Property row itself (Property.commissionPercentage /
  // commissionFlatFee). Optional — leave null to require per-property values.
  defaultBasePercent Decimal? @map("default_base_percent") @db.Decimal(7, 4)

  // Operational config
  holdPeriodDays   Int     @default(7) @map("hold_period_days") // FR-5.12
  compressionRule  Boolean @default(true) @map("compression_rule") // FR-5.6 / BR-8

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  splits CommissionSplit[]
  audits CommissionAudit[]

  @@index([organizationId, isActive, propertyType])
  @@index([propertyType, version])
  @@map("re_commission_rules")
}

enum CommissionSplitRole {
  LISTING_AGENT
  SELLING_AGENT
  BROKERAGE
  OVERRIDE
  RANK_BONUS
}

enum CommissionStatus {
  ON_HOLD
  RELEASED
  REVERSED
}

// One row per beneficiary of a transaction's commission. LISTING_AGENT,
// SELLING_AGENT and BROKERAGE rows are the FR-5.3 splits; OVERRIDE rows are
// the upline distribution (one per level), RANK_BONUS rows are FR-5.7 extras.
model CommissionSplit {
  id            String      @id @default(cuid())
  organizationId String     @map("organization_id")
  transactionId String      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  ruleId  String?         @map("rule_id")
  rule    CommissionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  role            CommissionSplitRole
  // For OVERRIDE rows: 1, 2, 3 = depth from the originating agent. Null for
  // listing/selling/brokerage rows.
  level           Int?
  // Beneficiary user (agent) — null for the BROKERAGE-house row, which is
  // tracked at org level only.
  beneficiaryUserId String?           @map("beneficiary_user_id")

  percent  Decimal           @db.Decimal(7, 4) // % applied
  amount   Decimal           @db.Decimal(14, 2) // computed amount
  status   CommissionStatus  @default(ON_HOLD)

  ledgerEntryId String? @unique @map("ledger_entry_id") // 1:1 with the credit row
  reversalLedgerEntryId String? @unique @map("reversal_ledger_entry_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([transactionId])
  @@index([beneficiaryUserId, status])
  @@map("re_commission_splits")
}

// One audit record per commission calculation (and per reversal). FR-5.10 —
// keeps the inputs, the rule snapshot, and the resulting splits as JSON so
// disputes can be answered without rerunning the engine.
model CommissionAudit {
  id            String      @id @default(cuid())
  organizationId String     @map("organization_id")
  transactionId String      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  ruleId      String?         @map("rule_id")
  rule        CommissionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  ruleVersion Int             @map("rule_version")

  kind  String // 'CALCULATE' | 'REVERSE' | 'RELEASE'
  inputs   Json // sale price, agents, rank chain, rule snapshot
  outputs  Json // split rows snapshot
  notes    String? @db.Text

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([transactionId, createdAt])
  @@index([organizationId, kind])
  @@map("re_commission_audits")
}

// ─────────────────────────────────────────────────────────────────────────────
// WALLET / LEDGER (FR-6)
// ─────────────────────────────────────────────────────────────────────────────

// One per User who participates in commissions. Created lazily when the user
// first earns / is debited. The summary fields are denormalised — they're a
// projection of the ledger and are recomputed on every write inside the same
// transaction so concurrent writes can't desync them.
model Wallet {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  userId         String @unique @map("user_id")
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency String @default("INR")

  // Sums of all RELEASED entries (credits − debits)
  availableBalance Decimal @default(0) @map("available_balance") @db.Decimal(14, 2)
  // Sums of all ON_HOLD entries (credits − debits) — pending release
  pendingBalance   Decimal @default(0) @map("pending_balance") @db.Decimal(14, 2)
  totalCredits     Decimal @default(0) @map("total_credits") @db.Decimal(14, 2)
  totalDebits      Decimal @default(0) @map("total_debits") @db.Decimal(14, 2)

  isFrozen     Boolean @default(false) @map("is_frozen")
  freezeReason String? @map("freeze_reason")

  ledgerEntries LedgerEntry[]
  withdrawals   WithdrawalRequest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("re_wallets")
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum LedgerCategory {
  COMMISSION
  OVERRIDE
  BONUS
  DESK_FEE
  MARKETING_FEE
  WITHDRAWAL
  REFUND
  ADJUSTMENT
  REVERSAL
  RANK_UP_BONUS
}

enum LedgerStatus {
  ON_HOLD
  RELEASED
  REVERSED
}

// Append-only financial movements. FR-6.2 / NFR-7. Application-layer code
// MUST never UPDATE or DELETE these rows. We only ever insert new rows
// (including offsetting reversals).
model LedgerEntry {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  walletId       String @map("wallet_id")
  wallet         Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type     LedgerEntryType
  category LedgerCategory
  status   LedgerStatus    @default(RELEASED)

  amount        Decimal @db.Decimal(14, 2) // always positive
  // Snapshot of the wallet's available balance after this row was applied —
  // makes statements straightforward to render.
  balanceAfter  Decimal @map("balance_after") @db.Decimal(14, 2)
  currency      String  @default("INR")

  description String?

  // Optional cross-references — at most one is set per row.
  transactionId    String?      @map("transaction_id")
  transaction      Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  splitId          String?      @map("split_id") // → CommissionSplit.id
  withdrawalId     String?      @map("withdrawal_id")
  reversesEntryId  String?      @map("reverses_entry_id") // → LedgerEntry.id

  releasedAt DateTime? @map("released_at")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([walletId, createdAt])
  @@index([walletId, status])
  @@index([transactionId])
  @@index([category, createdAt])
  @@map("re_ledger_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYOUTS (FR-7)
// ─────────────────────────────────────────────────────────────────────────────

// Bank account for an agent. FR-7.1 — accountNumber stored encrypted at the
// application layer; we keep accountNumberLast4 plaintext for UI display.
model BankAccount {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  userId         String  @map("user_id")

  label             String?
  bankName          String  @map("bank_name")
  accountHolderName String  @map("account_holder_name")
  // Encrypted at rest (AES-256 — encryption key from REBM_BANK_KEY env var)
  accountNumberEncrypted String @map("account_number_encrypted")
  accountNumberLast4     String @map("account_number_last4")
  ifscOrSwift            String @map("ifsc_or_swift")
  branch                 String?
  country                String  @default("IN")

  isPrimary  Boolean @default(false) @map("is_primary")
  verifiedAt DateTime? @map("verified_at")

  withdrawals WithdrawalRequest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@map("re_bank_accounts")
}

enum WithdrawalStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPLIANCE (Phase 3 — FR-8)
// One row per uploaded KYC / license / agreement file. The agent's overall
// AgentProfile.complianceStatus is auto-derived from these rows: COMPLIANT
// when every REQUIRED type has a VERIFIED row whose expiry is in the future.
// ─────────────────────────────────────────────────────────────────────────────

enum ComplianceDocumentType {
  GOVERNMENT_ID
  REAL_ESTATE_LICENSE
  TAX_FORM
  AGENCY_AGREEMENT
  ADDRESS_PROOF
  OTHER
}

enum ComplianceDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model ComplianceDocument {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  agentProfileId String       @map("agent_profile_id")
  agentProfile   AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)

  type ComplianceDocumentType
  name String
  url  String

  documentNumber String?   @map("document_number")
  issuedBy       String?   @map("issued_by")
  issuedAt       DateTime? @map("issued_at")
  expiryDate     DateTime? @map("expiry_date")

  status          ComplianceDocumentStatus @default(PENDING)
  rejectionReason String?                  @map("rejection_reason") @db.Text

  verifiedById String?   @map("verified_by_id") // → User.id
  verifiedAt   DateTime? @map("verified_at")

  uploadedById String   @map("uploaded_by_id") // → User.id
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([agentProfileId, status])
  @@index([type])
  @@index([expiryDate])
  @@map("re_compliance_documents")
}

// Withdrawal request from an agent's wallet. FR-7.4 — routes through approval
// (Compliance Officer → Admin payment). The state machine is enforced in the
// handler.
model WithdrawalRequest {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  walletId String @map("wallet_id")
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  userId String @map("user_id") // requester / wallet owner

  bankAccountId String       @map("bank_account_id")
  bankAccount   BankAccount  @relation(fields: [bankAccountId], references: [id])

  amount      Decimal @db.Decimal(14, 2)
  fee         Decimal @default(0) @db.Decimal(14, 2)
  netAmount   Decimal @map("net_amount") @db.Decimal(14, 2) // amount − fee
  currency    String  @default("INR")

  status WithdrawalStatus @default(REQUESTED)

  // Approval & payment tracking
  approvedById   String?   @map("approved_by_id")
  approvedAt     DateTime? @map("approved_at")
  rejectedById   String?   @map("rejected_by_id")
  rejectedAt     DateTime? @map("rejected_at")
  rejectionReason String?  @map("rejection_reason")
  paidById       String?   @map("paid_by_id")
  paidAt         DateTime? @map("paid_at")
  paymentReference String? @map("payment_reference")
  failureReason   String?  @map("failure_reason")

  // Ledger debit row that holds the funds while the request is in-flight
  holdLedgerEntryId String? @unique @map("hold_ledger_entry_id")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([walletId])
  @@map("re_withdrawal_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY (Module #3)
//
// A product has TWO faces:
//   • A structured **form** of fields (basic + advanced) that ops staff fill in
//     — name, SKU, price, stock, SEO meta, dimensions, etc.
//   • A **page layout** (12-col grid of blocks) that defines how the product
//     detail page renders on the storefront. Stored as JSON in `pageLayout`,
//     consumed by both the builder canvas and the public /storefront route.
//
// The form is the source of truth for *data*. The page layout describes how
// that data is *presented*. Blocks pull from the structured fields by name
// (e.g. a "title" block reads product.name), and a few free blocks (heading,
// text, image, html, spacer, divider) carry their own content.
// ─────────────────────────────────────────────────────────────────────────────

enum InventoryProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model InventoryProduct {
  id             String                 @id @default(cuid())
  organizationId String                 @map("organization_id")

  // Basics
  name             String
  slug             String
  sku              String?
  shortDescription String?                @map("short_description")
  description      String?                @db.Text
  status           InventoryProductStatus @default(DRAFT)

  // Pricing
  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2) @map("compare_at_price")
  currency       String   @default("INR")
  taxRate        Decimal? @db.Decimal(5, 2) @map("tax_rate")

  // Inventory
  stockQty          Int     @default(0) @map("stock_qty")
  trackStock        Boolean @default(true) @map("track_stock")
  lowStockThreshold Int?    @map("low_stock_threshold")

  // Categorization
  brand    String?
  category String?
  tags     Json    @default("[]") // string[]

  // Media
  primaryImageUrl String? @map("primary_image_url")
  images          Json    @default("[]") // [{ url, alt? }]

  // Variants — { name, options:[{label,priceDelta?,sku?}] }[]
  variants Json @default("[]")

  // Specs — { label, value }[]
  specs Json @default("[]")

  // SEO (advanced)
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")
  metaKeywords    String? @map("meta_keywords")

  // Shipping (advanced)
  weight     Decimal? @db.Decimal(10, 3)
  weightUnit String?  @map("weight_unit")
  dimensions Json?    // { length, width, height, unit }

  // Storefront layout — { rows: [{ id, blocks: [{ id, type, colSpan, props }] }] }
  pageLayout Json? @map("page_layout")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, sku])
  @@map("inventory_products")
}

// ─────────────────────────────────────────────────────────────────────────────
// REBM PHASE 4 — Plan Designer, RERA, Team Self-Service
// ─────────────────────────────────────────────────────────────────────────────

// Module-level settings for Real Estate Brokerage (one row per org).
model RebmSettings {
  id             String  @id @default(cuid())
  organizationId String  @unique @map("organization_id")

  // RERA gate — when true, transaction close is blocked unless both agents
  // are RERA-verified. Configurable so orgs can onboard before enforcement.
  isReraRequired Boolean @default(false) @map("is_rera_required")

  // Which plan engine to use: "LEGACY" (% of sale price) or "SLAB" (₹/sq.yd).
  planEngine String @default("LEGACY") @map("plan_engine")

  // ID of the currently active CompPlan (null = use legacy CommissionRule).
  activePlanId String? @map("active_plan_id")

  // Area unit used by the slab engine.
  areaUnit String @default("SQYD") @map("area_unit") // SQYD | SQFT | SQM

  // Hold period override (days) — applies to slab plan payouts.
  holdPeriodDays Int @default(7) @map("hold_period_days")

  // Company / brokerage residual percent kept by house after plan payouts.
  companyResidualPercent Decimal @default(0) @map("company_residual_percent") @db.Decimal(7, 4)

  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  @@map("rebm_settings")
}

// ─── RERA fields patched onto AgentProfile via separate model ────────────────
// (AgentProfile itself is not changed to avoid a full migration on existing
//  rows; this is a 1-1 extension table.)
model AgentReraProfile {
  id      String       @id @default(cuid())
  agentId String       @unique @map("agent_id")
  agent   AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)

  reraNumber     String?   @map("rera_number")
  reraState      String?   @map("rera_state")      // state issuing the certificate
  reraExpiresAt  DateTime? @map("rera_expires_at")
  reraVerifiedAt DateTime? @map("rera_verified_at")
  reraVerifiedBy String?   @map("rera_verified_by") // User.id of admin who verified
  reraDocUrl     String?   @map("rera_doc_url")     // uploaded certificate URL

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("re_agent_rera_profiles")
}

// ─── Compensation Plan (Plan Designer) ───────────────────────────────────────

enum CompPlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Top-level plan document. One ACTIVE plan per org at a time. Plans are
// immutable once ACTIVE — edits produce a new DRAFT version.
model CompPlan {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  name           String
  description    String?       @db.Text
  version        Int           @default(1)
  status         CompPlanStatus @default(DRAFT)

  // Area unit for all slabs in this plan (SQYD / SQFT / SQM).
  areaUnit String @default("SQYD") @map("area_unit")

  // Company residual % kept after all slab/override payouts.
  companyResidualPercent Decimal @default(0) @map("company_residual_percent") @db.Decimal(7, 4)

  // Compression: skip SUSPENDED/TERMINATED agents when walking overrides.
  compressionEnabled Boolean @default(true) @map("compression_enabled")

  // Whether Plan 3 override uses the absolute level-factor amounts (₹/sq.yd)
  // or percentage of the rate difference. "DIFF_FACTOR" = use the factor column
  // from CompPlanOverrideLevel directly as ₹/sq.yd absolute; "DIFF_RATE" =
  // factor is % multiplied onto (uplineRate − sellerRate).
  overrideMode String @default("DIFF_RATE") @map("override_mode")

  // Slab counter scope: "LIFETIME" or "ANNUAL" (resets each April 1 in India).
  slabCounterScope String @default("LIFETIME") @map("slab_counter_scope")

  createdById String   @map("created_by_id")
  activatedAt DateTime? @map("activated_at")
  activatedBy String?  @map("activated_by")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  slabs        CompPlanSlab[]
  overrideLevels CompPlanOverrideLevel[]
  designations CompPlanDesignation[]
  guarantees   CompPlanGuarantee[]
  areaLedgerEntries AgentAreaLedger[]

  @@index([organizationId, status])
  @@map("re_comp_plans")
}

// Plan 1 & 2 — direct income slab table. One row per slab.
// Rate = ₹ per sq.yd (or configured area unit).
model CompPlanSlab {
  id     String   @id @default(cuid())
  planId String   @map("plan_id")
  plan   CompPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  sortOrder  Int     @map("sort_order") // 0-based; determines slab boundary order
  minArea    Decimal @map("min_area") @db.Decimal(14, 2) // inclusive lower bound
  maxArea    Decimal? @map("max_area") @db.Decimal(14, 2) // null = unlimited (last slab)
  ratePerUnit Decimal @map("rate_per_unit") @db.Decimal(14, 4) // ₹ per sq.yd

  @@index([planId, sortOrder])
  @@map("re_comp_plan_slabs")
}

// Plan 3 — override ladder. One row per depth level (1..10).
// factor: when overrideMode=DIFF_RATE it is a multiplier on (uplineRate−sellerRate).
//         when overrideMode=DIFF_FACTOR it is a flat ₹/sq.yd absolute amount.
model CompPlanOverrideLevel {
  id     String   @id @default(cuid())
  planId String   @map("plan_id")
  plan   CompPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  level  Int     // 1 = immediate upline, 10 = deepest
  factor Decimal @db.Decimal(10, 4) // see overrideMode

  @@unique([planId, level])
  @@map("re_comp_plan_override_levels")
}

// Plan 4 — designation milestones. Cumulative area threshold → designation + reward.
model CompPlanDesignation {
  id     String   @id @default(cuid())
  planId String   @map("plan_id")
  plan   CompPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  sortOrder         Int     @map("sort_order")
  minCumulativeArea Decimal @map("min_cumulative_area") @db.Decimal(14, 2)
  designationCode   String  @map("designation_code") // e.g. BP, SBP, RBP
  designationName   String  @map("designation_name") // e.g. Business Partner
  rewardType        String  @map("reward_type") // TRAVEL | CASH | NONE | SURPRISE
  rewardDescription String? @map("reward_description") @db.Text // e.g. "International Tour — Malaysia, Thailand"
  rewardCashAmount  Decimal? @map("reward_cash_amount") @db.Decimal(14, 2) // if CASH

  @@index([planId, sortOrder])
  @@map("re_comp_plan_designations")
}

// Plan 5 — leader guarantee. Designation → monthly guaranteed amount.
model CompPlanGuarantee {
  id     String   @id @default(cuid())
  planId String   @map("plan_id")
  plan   CompPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  designationCode String  @map("designation_code") // must match CompPlanDesignation.designationCode
  monthlyAmount   Decimal @map("monthly_amount") @db.Decimal(14, 2)
  currency        String  @default("INR")

  @@unique([planId, designationCode])
  @@map("re_comp_plan_guarantees")
}

// ─── Area Ledger (append-only sq.yd tracking per agent) ──────────────────────

model AgentAreaLedger {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  agentId        String  @map("agent_id")  // AgentProfile.id
  planId         String  @map("plan_id")   // CompPlan under which the deal was counted
  plan           CompPlan @relation(fields: [planId], references: [id])

  transactionId  String  @map("transaction_id") // re_transactions.id
  dealArea       Decimal @map("deal_area") @db.Decimal(14, 2) // area of this deal
  cumulativeArea Decimal @map("cumulative_area") @db.Decimal(14, 2) // running total after this entry
  rateApplied    Decimal @map("rate_applied") @db.Decimal(14, 4) // ₹/unit used for this deal
  directIncome   Decimal @map("direct_income") @db.Decimal(14, 2) // = dealArea × rateApplied

  // Reversal flag — set when the transaction is cancelled
  isReversed     Boolean  @default(false) @map("is_reversed")
  reversedAt     DateTime? @map("reversed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, agentId, createdAt])
  @@index([transactionId])
  @@map("re_agent_area_ledger")
}

// ─── Reward Grants (Plan 4 milestone gifts) ───────────────────────────────────

enum RewardGrantStatus {
  PENDING    // milestone crossed; reward not yet fulfilled
  FULFILLED  // admin marked as fulfilled
  CANCELLED  // transaction reversed before fulfilment
}

model RewardGrant {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  agentId        String            @map("agent_id")
  planId         String            @map("plan_id")
  designationCode String           @map("designation_code")
  designationName String           @map("designation_name")
  rewardType      String           @map("reward_type")
  rewardDescription String?        @map("reward_description") @db.Text
  rewardCashAmount  Decimal?       @map("reward_cash_amount") @db.Decimal(14, 2)
  status          RewardGrantStatus @default(PENDING)
  triggeredByArea Decimal          @map("triggered_by_area") @db.Decimal(14, 2)
  fulfilledAt     DateTime?        @map("fulfilled_at")
  fulfilledById   String?          @map("fulfilled_by_id")
  notes           String?          @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([organizationId, agentId])
  @@index([organizationId, status])
  @@map("re_reward_grants")
}

// ─── Guarantee Payouts (Plan 5 monthly credits) ───────────────────────────────

model GuaranteePayout {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  agentId        String  @map("agent_id")
  planId         String  @map("plan_id")
  designationCode String @map("designation_code")
  periodYear     Int     @map("period_year")  // e.g. 2026
  periodMonth    Int     @map("period_month") // 1-12
  amount         Decimal @map("amount") @db.Decimal(14, 2)
  currency       String  @default("INR")
  ledgerEntryId  String? @map("ledger_entry_id") // LedgerEntry.id
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([organizationId, agentId, planId, periodYear, periodMonth])
  @@index([organizationId, periodYear, periodMonth])
  @@map("re_guarantee_payouts")
}

// ─── Invite Tokens (agent self-onboarding) ───────────────────────────────────

enum InviteTokenStatus {
  PENDING   // created, not yet used
  USED      // redeemed — AgentProfile created
  EXPIRED   // past expiresAt without use
  CANCELLED // admin revoked
}

model InviteToken {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  token          String            @unique // URL-safe random string
  sponsorAgentId String            @map("sponsor_agent_id") // AgentProfile.id of inviter
  // parentAgentId defaults to sponsorAgentId but admin can override
  parentAgentId  String?           @map("parent_agent_id")

  status         InviteTokenStatus @default(PENDING)
  expiresAt      DateTime          @map("expires_at")

  // Pre-filled fields shown on the join form
  prefillName  String? @map("prefill_name")
  prefillEmail String? @map("prefill_email")
  prefillPhone String? @map("prefill_phone")

  // Redemption
  redeemedByUserId  String?   @map("redeemed_by_user_id")
  redeemedByAgentId String?   @map("redeemed_by_agent_id")
  redeemedAt        DateTime? @map("redeemed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, sponsorAgentId])
  @@index([token])
  @@map("re_invite_tokens")
}

